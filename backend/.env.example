DATABASE_URL=postgresql+asyncpg://careerdev:careerdev@localhost:5432/careerdev
DATABASE_URL_SYNC=postgresql://careerdev:careerdev@localhost:5432/careerdev
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Google OAuth (optional — get credentials from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend). Set these in your host's dashboard (Railway → service → Variables).
RESEND_API_KEY=
EMAIL_FROM=noreply@crewtransition.com
# Newsletter / admin-broadcast sender + where replies go (a real inbox you read)
NEWSLETTER_FROM=CrewTransition <newsletter@crewtransition.com>
NEWSLETTER_REPLY_TO=crewtransition.app@gmail.com
# Physical mailing address required in bulk-email footers (CAN-SPAM / Gmail bulk rules)
NEWSLETTER_SENDER_ADDRESS=

