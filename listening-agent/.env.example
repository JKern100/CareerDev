# Copy this file to `.env` in the same folder and fill in your own values.
# See README.md → "One-time setup" for where to get each value.

# Reddit "script" app credentials (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=crewtransition-listener/0.1 by your_reddit_username

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here
